    "from datetime import datetime\n",
    "from pymongo import MongoClient\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.service import Service\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "from webdriver_manager.chrome import ChromeDriverManager\n",
    "import time\n",
    "import re\n",
    "import random\n",
    "import requests\n",
    "import feedparser\n",
    "\n",
    "# ==========================================\n",
    "# CONEXION MONGODB\n",
    "# ==========================================\n",
    "client = MongoClient(\"mongodb://bigdata_mongodb1:27017/\")\n",
    "db = client[\"proyecto_bigdata\"]\n",
    "coleccion = db[\"datos_scraping\"]\n",
    "\n",
    "print(\"✅ Conectado a MongoDB\")\n",
    "\n",
    "# ==========================================\n",
    "# OBTENER DOLAR (2 FUENTES - PRO)\n",
    "# ==========================================\n",
    "def obtener_dolar():\n",
    "\n",
    "    # Fuente 1\n",
    "    try:\n",
    "        url1 = \"https://mindicador.cl/api/dolar\"\n",
    "        r1 = requests.get(url1, timeout=5)\n",
    "        data1 = r1.json()\n",
    "\n",
    "        precio = data1[\"serie\"][0][\"valor\"]\n",
    "        print(f\"💰 Dólar (mindicador): {precio}\")\n",
    "        return precio\n",
    "\n",
    "    except:\n",
    "        print(\"⚠️ Falla fuente 1... intentando fuente 2\")\n",
    "\n",
    "    # Fuente 2 (backup)\n",
    "    try:\n",
    "        url2 = \"https://open.er-api.com/v6/latest/USD\"\n",
    "        r2 = requests.get(url2, timeout=5)\n",
    "        data2 = r2.json()\n",
    "\n",
    "        if \"rates\" in data2:\n",
    "            precio = data2[\"rates\"][\"CLP\"]\n",
    "            print(f\"💰 Dólar (API backup): {precio}\")\n",
    "            return precio\n",
    "\n",
    "    except Exception as e:\n",
    "        print(\"❌ Error total obteniendo dólar:\", e)\n",
    "\n",
    "    return None\n",
    "\n",
    "# ==========================================\n",
    "# OBTENER NOTICIAS\n",
    "# ==========================================\n",
    "def obtener_noticias():\n",
    "\n",
    "    url = \"https://news.google.com/rss/search?q=dolar+Chile+economia&hl=es-419&gl=CL&ceid=CL:es\"\n",
    "\n",
    "    noticias = []\n",
    "\n",
    "    try:\n",
    "        feed = feedparser.parse(url)\n",
    "\n",
    "        for entrada in feed.entries[:30]:  # más noticias\n",
    "            noticias.append({\n",
    "                \"titulo\": entrada.title,\n",
    "                \"link\": entrada.link,\n",
    "                \"fecha\": entrada.published\n",
    "            })\n",
    "\n",
    "        print(f\"📰 Noticias obtenidas: {len(noticias)}\")\n",
    "        return noticias\n",
    "\n",
    "    except Exception as e:\n",
    "        print(\"❌ Error obteniendo noticias:\", e)\n",
    "        return []\n",
    "\n",
    "# ==========================================\n",
    "# ANALISIS DE IMPACTO\n",
    "# ==========================================\n",
    "def analizar_tendencia(titulo):\n",
    "\n",
    "    texto = titulo.lower()\n",
    "\n",
    "    if any(p in texto for p in [\"guerra\", \"crisis\", \"inflacion\", \"alza\", \"sube\"]):\n",
    "        return \"ALZA 📈\"\n",
    "\n",
    "    elif any(p in texto for p in [\"baja\", \"cae\", \"acuerdo\", \"estabilidad\"]):\n",
    "        return \"BAJA 📉\"\n",
    "\n",
    "    else:\n",
    "        return \"NEUTRO\"\n",
    "\n",
    "# ==========================================\n",
    "# EVITAR DUPLICADOS\n",
    "# ==========================================\n",
    "def noticia_existe(titulo):\n",
    "    return coleccion.count_documents({\"nombre\": titulo}) > 0\n",
    "\n",
    "# ==========================================\n",
    "# SCRAPING PRINCIPAL\n",
    "# ==========================================\n",
    "def ejecutar_scraping():\n",
    "\n",
    "    print(\"=\"*50)\n",
    "    print(\"📊 INICIO PROCESO FINANCIERO PRO\")\n",
    "    print(\"=\"*50)\n",
    "\n",
    "    antes = coleccion.count_documents({})\n",
    "    print(\"📦 Registros antes:\", antes)\n",
    "\n",
    "    dolar = obtener_dolar()\n",
    "\n",
    "    if dolar is None:\n",
    "        print(\"❌ No se pudo obtener el dólar\")\n",
    "        return\n",
    "\n",
    "    noticias = obtener_noticias()\n",
    "\n",
    "    guardados = 0\n",
    "\n",
    "    for noticia in noticias:\n",
    "\n",
    "        titulo = noticia[\"titulo\"]\n",
    "        link = noticia[\"link\"]\n",
    "\n",
    "        # evitar duplicados\n",
    "        if noticia_existe(titulo):\n",
    "            print(\"⚠️ Ya existe:\", titulo[:40])\n",
    "            continue\n",
    "\n",
    "        tendencia = analizar_tendencia(titulo)\n",
    "\n",
    "        # ======================================\n",
    "        # REGISTRO FINAL (ORDEN CORRECTO)\n",
    "        # ======================================\n",
    "        registro = {\n",
    "            \"tipo\": \"mercado_financiero\",\n",
    "\n",
    "            \"nombre\": titulo,\n",
    "            \"precio_dolar\": dolar,\n",
    "\n",
    "            \"categoria\": \"Finanzas\",\n",
    "            \"subcategoria\": \"Mercado Divisas\",\n",
    "\n",
    "            \"moneda\": \"CLP\",\n",
    "            \"tendencia\": tendencia,\n",
    "\n",
    "            \"fecha\": datetime.now(),\n",
    "\n",
    "            # 🔗 SIEMPRE AL FINAL\n",
    "            \"url_fuente\": link,\n",
    "            \"fuente\": \"Google News\"\n",
    "        }\n",
    "\n",
    "        coleccion.insert_one(registro)\n",
    "        guardados += 1\n",
    "\n",
    "        print(f\"✅ Guardado: {titulo[:50]}...\")\n",
    "\n",
    "    despues = coleccion.count_documents({})\n",
    "\n",
    "    print(\"=\"*50)\n",
    "    print(\"📊 RESULTADO FINAL\")\n",
    "    print(\"=\"*50)\n",
    "    print(\"Antes:\", antes)\n",
    "    print(\"Ahora:\", despues)\n",
    "    print(\"Nuevos:\", despues - antes)\n",
    "    print(\"=\"*50)\n",
    "\n",
    "# ==========================================\n",
    "# EJECUTAR\n",
    "# ==========================================\n",
    "ejecutar_scraping()"
   ]
