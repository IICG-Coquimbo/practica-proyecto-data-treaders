    "from datetime import datetime\n",
    "from pymongo import MongoClient\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.service import Service\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "from webdriver_manager.chrome import ChromeDriverManager\n",
    "import time\n",
    "import re\n",
    "import random\n",
    "import requests\n",
    "import feedparser\n",
    "\n",
    "# ==========================================\n",
    "# CONEXION MONGODB\n",
    "# ==========================================\n",
    "client = MongoClient(\"mongodb://bigdata_mongodb1:27017/\")\n",
    "db = client[\"proyecto_bigdata\"]\n",
    "coleccion = db[\"datos_scraping\"]\n",
    "\n",
    "print(\"✅ Conectado a MongoDB\")\n",
    "\n",
    "# ==========================================\n",
    "# OBTENER DÓLAR\n",
    "# ==========================================\n",
    "def obtener_dolar():\n",
    "\n",
    "    url = \"https://mindicador.cl/api/dolar\"\n",
    "\n",
    "    try:\n",
    "        response = requests.get(url)\n",
    "        data = response.json()\n",
    "\n",
    "        precio = data[\"serie\"][0][\"valor\"]\n",
    "\n",
    "        print(f\"💰 Dólar actual: {precio}\")\n",
    "\n",
    "        return precio\n",
    "\n",
    "    except Exception as e:\n",
    "        print(\"❌ Error obteniendo dólar:\", e)\n",
    "        return None\n",
    "\n",
    "# ==========================================\n",
    "# OBTENER NOTICIAS\n",
    "# ==========================================\n",
    "def obtener_noticias():\n",
    "\n",
    "    url = \"https://news.google.com/rss/search?q=dolar+economia+Chile&hl=es-419&gl=CL&ceid=CL:es\"\n",
    "\n",
    "    noticias = []\n",
    "\n",
    "    try:\n",
    "        feed = feedparser.parse(url)\n",
    "\n",
    "        for entrada in feed.entries[:10]:\n",
    "            noticias.append({\n",
    "                \"titulo\": entrada.title,\n",
    "                \"link\": entrada.link,\n",
    "                \"fecha\": entrada.published\n",
    "            })\n",
    "\n",
    "        print(f\"📰 Noticias obtenidas: {len(noticias)}\")\n",
    "\n",
    "        return noticias\n",
    "\n",
    "    except Exception as e:\n",
    "        print(\"❌ Error obteniendo noticias:\", e)\n",
    "        return []\n",
    "\n",
    "# ==========================================\n",
    "# ANALIZAR IMPACTO\n",
    "# ==========================================\n",
    "def analizar_impacto(titulo):\n",
    "\n",
    "    texto = titulo.lower()\n",
    "\n",
    "    if \"guerra\" in texto or \"crisis\" in texto or \"inflacion\" in texto:\n",
    "        return \"ALZA 📈\"\n",
    "    elif \"acuerdo\" in texto or \"baja\" in texto or \"cae\" in texto:\n",
    "        return \"BAJA 📉\"\n",
    "    else:\n",
    "        return \"NEUTRO\"\n",
    "\n",
    "# ==========================================\n",
    "# SCRAPING\n",
    "# ==========================================\n",
    "def ejecutar_scraping():\n",
    "\n",
    "    print(\"=\"*50)\n",
    "    print(\"📊 INICIO PROCESO FINANCIERO\")\n",
    "    print(\"=\"*50)\n",
    "\n",
    "    antes = coleccion.count_documents({})\n",
    "    print(\"📦 Registros antes:\", antes)\n",
    "\n",
    "    dolar = obtener_dolar()\n",
    "\n",
    "    if dolar is None:\n",
    "        print(\"❌ No se pudo obtener el dólar\")\n",
    "        return\n",
    "\n",
    "    noticias = obtener_noticias()\n",
    "\n",
    "    guardados = 0\n",
    "\n",
    "    for noticia in noticias:\n",
    "\n",
    "        titulo = noticia[\"titulo\"]\n",
    "        link = noticia[\"link\"]\n",
    "        impacto = analizar_impacto(titulo)\n",
    "        \n",
    "        existe = coleccion.count_documents({\"url_fuente\": link})\n",
    "        if existe > 0:\n",
    "            print(\"Noticia repetida, se omite\")\n",
    "            continue\n",
    "\n",
    "        # ======================================\n",
    "        # REGISTRO CORRECTO\n",
    "        # ======================================\n",
    "        registro = {\n",
    "\n",
    "            \"tipo\": \"mercado_financiero\",\n",
    "\n",
    "            \"nombre\": \"USD/CLP\",\n",
    "            \"precio_dolar\": dolar,\n",
    "\n",
    "            \"noticia\": titulo,\n",
    "\n",
    "            \"categoria\": \"Finanzas\",\n",
    "            \"subcategoria\": \"Mercado Divisas\",\n",
    "            \"moneda\": \"CLP\",\n",
    "            \"tendencia\": impacto,\n",
    "\n",
    "            \"fecha\": datetime.now(),\n",
    "\n",
    "            \"fuente_dolar\": \"mindicador.cl\",\n",
    "            \"fuente_noticia\": \"Google News\",\n",
    "\n",
    "            # 🔗 AL FINAL (como te pidió el profe probablemente)\n",
    "            \"url_fuente\": link\n",
    "\n",
    "        }\n",
    "\n",
    "        coleccion.insert_one(registro)\n",
    "        guardados += 1\n",
    "\n",
    "        print(f\"✅ Guardado: {titulo[:50]}...\")\n",
    "\n",
    "    despues = coleccion.count_documents({})\n",
    "\n",
    "    print(\"=\"*50)\n",
    "    print(\"📊 RESULTADO FINAL\")\n",
    "    print(\"=\"*50)\n",
    "    print(\"Antes:\", antes)\n",
    "    print(\"Ahora:\", despues)\n",
    "    print(\"Nuevos:\", despues - antes)\n",
    "    print(\"=\"*50)\n",
    "\n",
    "# ==========================================\n",
    "# EJECUTAR\n",
    "# ==========================================\n",
    "ejecutar_scraping()"
   ]
